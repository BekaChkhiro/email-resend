# Database connection (same as main app)
DATABASE_URL="postgresql://user:password@localhost:5432/email_campaign"

# Server mode (stdio or http)
MCP_MODE="stdio"

# HTTP mode settings (only used when MCP_MODE=http)
MCP_HTTP_PORT=3100
MCP_API_KEY="your-api-key-here"

# Rate limiting (requests per minute)
MCP_RATE_LIMIT=60
